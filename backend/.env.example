# Sprint Lifecycle Dashboard — Backend Environment Configuration
# Copy this file to .env and fill in your real values

PORT=4600
NODE_ENV=development

# CORS — comma-separated list of allowed frontend origins
CORS_ORIGINS=http://localhost:3100,http://localhost:3101,http://127.0.0.1:3100

# ─── Jira ────────────────────────────────────────────────────────────────────
JIRA_BASE_URL=https://your-org.atlassian.net
# Base64-encoded "user@email.com:api-token" or Bearer token
# Generate token at: id.atlassian.com/manage-profile/security/api-tokens
JIRA_AUTH_TOKEN=
JIRA_BOARD_ID=
JIRA_POLL_INTERVAL=60000

# ─── Bitbucket ───────────────────────────────────────────────────────────────
BITBUCKET_BASE_URL=https://your-bitbucket-server.com
BITBUCKET_PROJECT_KEY=YOUR_PROJECT
BITBUCKET_AUTH_TOKEN=
BITBUCKET_DEFAULT_REPO=your-repo-name
BITBUCKET_POLL_INTERVAL=30000

# ─── Azure DevOps ─────────────────────────────────────────────────────────────
AZDO_ORG_URL=https://dev.azure.com/your-org
AZDO_CI_PROJECT=YourCIProject
AZDO_CD_PROJECT=YourCDProject
AZDO_PAT=
AZDO_CI_BRANCH=
AZDO_CD_BRANCH=
AZDO_CD_LINK_VAR=PR_ID
AZDO_POLL_INTERVAL=30000

# ─── Copilot Review ──────────────────────────────────────────────────────────
COPILOT_REVIEW_URL=

# ─── AI Scaffold (GitHub Models — gpt-4o via OpenAI-compatible API) ──────────
# Generate at: github.com/settings/tokens (no special scopes needed)
GITHUB_TOKEN=
CLAUDE_MODEL=gpt-4o

# ─── SpecDev ─────────────────────────────────────────────────────────────────
SPECDEV_TARGET_BRANCH=develop
SPECDEV_BRANCH_PREFIX=feature
SPECDEV_UPLOADS_DIR=uploads/proofs
# Absolute path to the local checkout of the target repo (for reading spec files from disk)
# Example: C:\repos\your-repo  or  /home/user/repos/your-repo
LOCAL_REPO_PATH=
